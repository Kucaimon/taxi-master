# Public bundle inputs. Anything here ends up in the JS bundle, so do not
# put true secrets — only browser-safe identifiers and keys that are
# expected to be Referrer-restricted on the provider side.

# HERE Maps API key (https://platform.here.com).
# Restrict the key by Referrer ("https://your.domain/*") in the HERE console.
REACT_APP_HERE_API_KEY=

# Realtime transport mode used by src/services/realtime.
# Allowed values:
#   polling   — always use the axios-based polling transport (today's behaviour).
#   websocket — always use the WebSocket transport (NOT wired yet; will throw on
#               every connect attempt until the backend ships a WS endpoint).
#   auto      — try WebSocket, transparently fall back to polling on error or if
#               no `open` is received within a few seconds. Default.
# Because the WebSocket transport is currently a stub, both `auto` and an unset
# value resolve to polling at runtime — flipping the WS implementation on later
# requires no consumer changes.
REACT_APP_REALTIME_MODE=auto
